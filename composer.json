{
    "name": "sunnysideup/silverstripe-externalurlfield",
    "description": "Provides SilverStripe with a DBField and FormField for handling external URLs.",
    "type": "silverstripe-vendormodule",
    "license": "MIT",
    "keywords": [
        "silverstripe",
        "url",
        "link",
        "form",
        "field"
    ],
    "require": {
        "silverstripe/framework": "^6.0",
        "jakeasmith/http_build_url": "^1"
    },
    "require-dev": {
        "phpunit/phpunit": "^5.7",
        "squizlabs/php_codesniffer": "^3.0"
    },
    "authors": [
        {
            "name": "Jeremy Shipman",
            "homepage": "https://github.com/jedateach",
            "role": "Developer"
        }
    ],
    "autoload": {
        "psr-4": {
            "Sunnysideup\\ExternalURLField\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}